programa
{
    funcao inicio()
    {
        // Declara as variaveis primeiro
        inteiro idade 

        escreva("Digite sua idade: ")
        leia(idade)

        // verifica a idade
        se (idade >= 18) 
        {
            escreva("Usuário aprovado")
        }
        senao 
        {
            escreva("Usuário reprovado")
        }
    }
}
