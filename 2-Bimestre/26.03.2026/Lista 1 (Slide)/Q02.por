programa {
  funcao inicio()
  {
    inteiro posicoes [5]

      para (inteiro i = 0; i < 5; i++)
      
        {
          escreva("Digite o valor: ")
          leia(posicoes[i])
        }
      para (inteiro i = 0; i < 5; i++)
        
        {
          escreva("\nOs Valores São: ",posicoes[i]*3)
        }
  }
}
